  <property name="styleSheet">
   <string notr="true">QMainWindow {
    background: #f6f8fb;
}

QWidget {
    color: #1f2933;
    font-family: &quot;Segoe UI&quot;, &quot;Arial&quot;;
    font-size: 15px;
}

QGroupBox {
    background: #ffffff;
    border: 1px solid #d7dde5;
    border-radius: 8px;
    margin-top: 18px;
    font-weight: 600;
    color: #1555b3;
}

QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    left: 12px;
    padding: 0 6px;
    background: #ffffff;
    color: #1555b3;
    font-size: 18px;
    font-weight: 700;
}

QPushButton {
    background: #ffffff;
    border: 1px solid #c9d1dc;
    border-radius: 7px;
    color: #1f2933;
    font-weight: 500;
}

QPushButton:hover {
    background: #f3f7fd;
    border-color: #9bb7df;
}

QPushButton:pressed {
    background: #dceaff;
    border-color: #1f5fbf;
}

QPushButton:checked {
    background: #e7f0ff;
    border: 2px solid #1f5fbf;
    color: #174a9c;
}

QPushButton:disabled {
    background: #edf0f3;
    border-color: #d2d7de;
    color: #98a1ad;
}

QLabel {
    background: transparent;
}

#visualPanelGroup,
#cabinPanelGroup,
#statusGroup,
#logGroup {
    background: #ffffff;
}

#floorNumberLabel1,
#floorNumberLabel2,
#floorNumberLabel3,
#floorNumberLabel4,
#floorNumberLabel5 {
    color: #174a9c;
    font-size: 34px;
    font-weight: 800;
}

#floorCaptionLabel1,
#floorCaptionLabel2,
#floorCaptionLabel3,
#floorCaptionLabel4,
#floorCaptionLabel5 {
    color: #2f3741;
    font-size: 16px;
}

#shaftFrame {
    background: #dde5ee;
    border: 2px solid #2d3742;
    border-radius: 0;
}

#leftRailFrame,
#rightRailFrame {
    background: #8798a8;
    border: 1px solid #25313b;
}

#floorDividerFrame2,
#floorDividerFrame3,
#floorDividerFrame4,
#floorDividerFrame5 {
    color: #303a44;
    background: #303a44;
}

#elevatorCabinFrame {
    background: #cfd9e4;
    border: 2px solid #111827;
}

#leftDoorFrame,
#rightDoorFrame {
    background: #d7e1eb;
    border: 1px solid #1f2933;
}

#callUpButton1,
#callUpButton2,
#callUpButton3,
#callUpButton4 {
    color: #168821;
    font-size: 30px;
    font-weight: 800;
}

#callDownButton2,
#callDownButton3,
#callDownButton4,
#callDownButton5 {
    color: #111827;
    font-size: 30px;
    font-weight: 800;
}

#callUpButton1:checked,
#callUpButton2:checked,
#callUpButton3:checked,
#callUpButton4:checked {
    background: #e8f8eb;
    border: 2px solid #168821;
    color: #0f7a1a;
}

#callDownButton2:checked,
#callDownButton3:checked,
#callDownButton4:checked,
#callDownButton5:checked {
    background: #e7f0ff;
    border: 2px solid #174a9c;
    color: #174a9c;
}

#cabinFloorButton1,
#cabinFloorButton2,
#cabinFloorButton3,
#cabinFloorButton4,
#cabinFloorButton5 {
    color: #174a9c;
    font-size: 32px;
    font-weight: 800;
}

#cabinFloorButton1:checked,
#cabinFloorButton2:checked,
#cabinFloorButton3:checked,
#cabinFloorButton4:checked,
#cabinFloorButton5:checked {
    background: #e7f0ff;
    border: 2px solid #174a9c;
}

#openDoorsButton,
#closeDoorsButton {
    font-size: 16px;
    min-height: 54px;
}

#currentFloorValueLabel,
#targetFloorValueLabel {
    color: #174a9c;
    font-size: 18px;
    font-weight: 800;
}

#directionValueLabel,
#cabinStateValueLabel {
    color: #4b5563;
    font-weight: 600;
}

#doorsStateValueLabel {
    color: #168821;
    font-weight: 700;
}

#eventLogEdit {
    background: #fbfcfe;
    border: 1px solid #c9d1dc;
    border-radius: 6px;
    color: #1f2933;
    font-family: &quot;Consolas&quot;, &quot;Courier New&quot;, monospace;
    font-size: 14px;
    selection-background-color: #cfe0ff;
}

#clearLogButton {
    min-height: 34px;
}
